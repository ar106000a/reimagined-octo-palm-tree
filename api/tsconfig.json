{
  "compilerOptions": {
    "target": "es2020",
    "module": "ESNext",
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@projects/types": ["../packages/types/index.ts"],
      "@projects/types/*": ["../packages/types/*"]
    }
  },
  "exclude": ["node_modules"],
  "drizzle-kit": { "config": "./drizzle.config.ts" }
}
